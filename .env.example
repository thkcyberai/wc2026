# ── OpenAI (server-side only — never exposed to the browser) ─────────────
# Used to normalize/clean fetched fixture data, match team names,
# standardize venues/statuses and explain refresh errors in plain language.
# NOT used as a source of scores.
OPENAI_API_KEY=sk-your-key-here

# Optional: OpenAI model used for normalization (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ── Official score source (recommended) ───────────────────────────────────
# Free key at https://www.football-data.org (FIFA World Cup competition id 2000).
# If unset, refresh falls back to the public openfootball JSON dataset.
FOOTBALL_DATA_API_KEY=

# ── Squads, player photos, goalscorers & cards (optional but recommended) ──
# Free key (100 requests/day): https://dashboard.api-sports.io
API_FOOTBALL_KEY=

# Optional: max API-Football calls per refresh/squad-load run (default 80)
# AF_MAX_CALLS=80

# Optional: path of the SQLite database file (default: ./data/wc2026.db)
# WC2026_DB_PATH=./data/wc2026.db
